<Window x:Class="GigTracker.Views.frmUpdateEntry"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GigTracker.Views"
        mc:Ignorable="d"
        Title="frmUpdateEntry" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="txtBandName" HorizontalAlignment="Left" Margin="242,80,0,0" TextWrapping="Wrap" Text="Band name" VerticalAlignment="Top" Width="257"/>
        <TextBox x:Name="txtVenueName" HorizontalAlignment="Left" Margin="242,115,0,0" TextWrapping="Wrap" Text="Venue name" VerticalAlignment="Top" Width="257"/>
        <DatePicker x:Name="txtDate" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="320,143,0,0" />
        <Button Content="Update Concert" HorizontalAlignment="Left" Margin="336,197,0,0" VerticalAlignment="Top" Click="UpdateButton_Click"/>

    </Grid>
</Window>
