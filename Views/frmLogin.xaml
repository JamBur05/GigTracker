<Window x:Class="GigTracker.Views.frmLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GigTracker.Views"
        mc:Ignorable="d"
        Title="frmLogin" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="txtUsername" HorizontalAlignment="Left" Margin="172,158,0,0" TextWrapping="Wrap" Text="Username" VerticalAlignment="Top" Width="410" Height="17"/>
        <Button Content="Submit" HorizontalAlignment="Left" Margin="358,255,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <PasswordBox x:Name="txtPassword" HorizontalAlignment="Left" Margin="172,199,0,0" VerticalAlignment="Top" Width="410" Height="18"/>
    </Grid>
</Window>
